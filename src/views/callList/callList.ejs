<script type="module" src="/js/callListScript.js"> </script>

<div class="callListDisplay">
    <!-- Call List Header -->
    <form class="grid_col_1 margin_t_med margin_b_med" id="datesForm" action="/setDates" method="GET">
        <div class="flex flex-ai-c">
            <!--
            <div>
                <input class="margin_r_sm" id="date1_input" type="date" name="date1" value="">
                to
                <input class="margin_l_sm" id="date2_input" type="date" name="date2" value="">
            </div>
            <button class="button_secondary margin_l_sm" type="submit"> Set </button>
            -->
            <label class="margin_r_sm"> Select month: </label>
            <input id="monthInputCL" type="month" name="monthCL" value="<%= locals.month %>">
        </div>
    </form>

    <!-- Call List -->
    <div class="grid_col_1">
        <!-- Header -->
        <div class="flex flex-ai-c flex-jc-sb">
            <input id="CLCheckbox" type="checkbox">
            <p class="color_primary size_medium"> Call List </p>
            <p> </p>
        </div>
        <hr />
        
        <div class="inner_section section_divider_callList">
            <ul id="cList">
                <% for (let i = 0; i < callList.length; i++) { %>
                    <li class="positionRelative"> 
                        <!-- Name button that appears in lists, brings up popup -->
                        <%- include("../partials/callList/callList-popupButton", {client: callList[i]}) %>
                        
                        <!-- Client Popup -->
                        <%- include("../partials/callList/callList-popup", {client: callList[i]}) %>
                    </li>
                <% } %>
            </ul>
        </div>

    </div>

    <!-- To Be Confirmed -->
    <div class="grid_col_2">
        <!-- Header -->
        <div class="flex flex-ai-c flex-jc-sb">
            <input id="TBCCheckbox" type="checkbox">
            <p class="flex flex-jc-c color_primary size_medium"> To be confirmed </p>
            <p> </p>
        </div>
        <hr />
        <div class="inner_section section_divider_callList">
            <ul id="tbcList">
                <% for (let i = 0; i < tbcList.length; i++) { %>
                    <li class="positionRelative"> 
                        <!-- Name button that appears in lists, brings up popup -->
                        <%- include("../partials/callList/callList-popupButton", {client: tbcList[i]}) %>
                        
                        <!-- Client Popup -->
                        <%- include("../partials/callList/callList-popup", {client: tbcList[i]}) %>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>

    <!-- Confirmed -->
    <div class="grid_col_3">
        <!-- Header and clear button-->
        <div class="flex flex-ai-c flex-jc-r"> 
            <div class="flex flex-ai-c flex-jc-sb confirmed_width">
                <p class="color_primary size_medium"> Confirmed </p> 
                <form action="/reset-confirmed-list" method="POST" class="flex flex-jc-r"> 
                    <button type="submit" class="button_clear"> Clear </button> 
                </form> 
            </div>
        </div>
        <hr />
        <div class="inner_section section_divider_confirmedList">
            <ul id="confirmedList">
                <% for (let i = 0; i < confirmedList.length; i++) { %>
                    <li class="positionRelative"> 
                        <!-- Name button that appears in lists, brings up popup -->
                        <%- include("../partials/callList/callList-popupButton", {client: confirmedList[i]}) %>
                        
                        <!-- Client Popup -->
                        <%- include("../partials/callList/callList-popup", {client: confirmedList[i]}) %>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</div>