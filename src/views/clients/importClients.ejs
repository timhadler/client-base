<script type="module" src="/js/importClientsScript.js"> </script>

<div class="clientListDisplay">
    <div class="grid_col_1 section_divider_clientList pad-t-med pad-r-sm">
        <h3> Import Clients </h3>
        <br />

        <div class="center-x">
            <button class="button_secondary margin_b_med"> Download Excel Template </button>

            <form id="clientImportForm" action="/clients/import-clients-preview" enctype="multipart/form-data" method="post">
                <label> Upload Client Excel File: </label> <br />
                <input id="clientImportFile" type="file" name="importExcel" class="clientsFile" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel" />
            </form>
        </div>
    </div>

    <div class="grid_col_2_s2 margin_t_l margin_l_l">
        <p class="error_message"> <%= locals.error %> </p>
        <p> <%= locals.message %> </p>
        <br />

        <% if (typeof locals.duplicates != 'undefined') { 
            let dupLength = locals.duplicates.length;
            if (dupLength > 0) { %>
                <p> <%= "There were " + dupLength + " clients with duplicate names already in database: " %> </p>
                <div class="inner_section">
                    <% for (let i = 0; i < dupLength; i++) { %>
                        <p> <%= duplicates[i] %> </p>
                    <% } %>
                </div>
            <% } %>
            <br />
        <% } %>

        <% if (typeof locals.fails != 'undefined') {
            let failLength = locals.fails.length;
            if (failLength > 0) { %>
                <p> Other errors: </p>
                <div class="inner_section">
                    <% for (let i = 0; i < locals.fails.length; i++) { %>
                        <p> <%= fails[i].name + ' - ' + fails[i].message %> </p>
                    <% } %>
                </div>
            <% } %>
        <% } %>
    </div>
</div>