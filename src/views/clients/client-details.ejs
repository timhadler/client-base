<script src="/js/jquery.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/clientDetailsScript.js"></script>

<div id="client-data" data-client-id="<%= clientId %>"></div>

<!-- Reminder modal -->
<%- include('../partials/_reminderModal'); %>

<!-- Delete Modal -->
<%- include('../partials/_confirmDeleteModal'); %>

<!-- Record Response Modal -->
<div class="cd-modal-overlay" id="recordResponseModal">
    <div class="cd-modal-container">
        <div class="cd-modal-header">
            <h2 class="cd-modal-title">Record Client Response</h2>
            <button class="cd-modal-close" id="closeResponseModal">×</button>
        </div>
        <div class="cd-modal-body">
            <div class="cd-interaction-summary">
                <div class="cd-interaction-summary-icon" id="responseModalIcon">✉️</div>
                <div class="cd-interaction-summary-content">
                    <div class="cd-interaction-summary-type" id="responseModalType"></div>
                    <div class="cd-interaction-summary-desc" id="responseModalDesc"></div>
                    <div class="cd-interaction-summary-date" id="responseModalDate"></div>
                </div>
            </div>
            
            <div class="cd-form-divider"></div>
            
            <form id="recordResponseForm">
                <div class="cd-form-group">
                    <label>How did the client respond?</label>
                    <div class="cd-outcome-buttons">
                        <button type="button" class="cd-outcome-btn" data-outcome="booked">
                            <span class="cd-outcome-icon">✓</span>
                            <span class="cd-outcome-label">Booked</span>
                        </button>
                        <button type="button" class="cd-outcome-btn" data-outcome="followup">
                            <span class="cd-outcome-icon">↻</span>
                            <span class="cd-outcome-label">Follow-up</span>
                        </button>
                        <button type="button" class="cd-outcome-btn" data-outcome="declined">
                            <span class="cd-outcome-icon">✕</span>
                            <span class="cd-outcome-label">Declined</span>
                        </button>
                        <button type="button" class="cd-outcome-btn" data-outcome="no_answer">
                            <span class="cd-outcome-icon">○</span>
                            <span class="cd-outcome-label">No Response</span>
                        </button>
                    </div>
                </div>
                
                <div class="cd-form-group" id="responseNotesGroup" style="display: none;">
                    <label>Additional Notes (Optional)</label>
                    <textarea class="cd-form-control" id="responseNotes" rows="2" placeholder="Any additional details about the response..."></textarea>
                </div>
                
                <div class="cd-modal-actions">
                    <button type="button" class="cd-btn-modal cd-btn-secondary" id="cancelRecordResponse">Cancel</button>
                    <button type="submit" class="cd-btn-modal cd-btn-primary" id="saveResponseBtn" disabled>Save Response</button>
                </div>
            </form>
        </div>
    </div>
</div>
    
<!-- Main Content -->
<main class="main-content">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="/clients">Clients</a>
        <span>›</span>
        <span style="color: var(--gray-900); font-weight: 600;" id="breadcrumbName">Loading...</span>
    </div>
    
    <!-- Client Header Card -->
    <div class="cd-header-card">
        <div class="cd-header-content">
            <div class="cd-main-info">
                <div class="cd-avatar-large" id="clientAvatar">
                    <!-- Avatar will be set via JS -->
                </div>
                <h1 class="cd-client-name" id="clientName">Loading...</h1>
                <div class="cd-client-company" id="clientCompany">-</div>
                
                <div class="cd-meta" id="clientMeta">
                    <!-- Meta items will be loaded via JS -->
                </div>
                
                <div class="cd-badges" id="clientBadges">
                    <!-- Badges will be loaded via JS -->
                </div>
            </div>
            
            <div class="cd-actions">
                <a href="#" class="cd-btn cd-btn-secondary" id="editBtn">
                    ✏️ Edit
                </a>
                <a href="#" class="cd-btn cd-btn-primary" id="addReminderBtn">
                    📅 Add Reminder
                </a>
                <button class="delete-btn delete-btn-confirm" id="confirmDeleteClientBtn">
                    <span>🗑️</span> 
                    <span>Delete</span>
                </button>
            </div>
        </div>
    </div>
    
    <!-- Content Grid -->
    <div class="cd-content-grid">
        <!-- Left Column -->
        <div>
            <!-- Reminders -->
            <div class="cd-content-card" style="margin-bottom: 24px;">
                <div class="cd-card-header">
                    <h2 class="cd-card-title">Upcoming Reminders</h2>
                    <p class="cd-subtitle" id="remindersLimitText"></p>
                </div>
                
                <div class="cd-reminder-list" id="remindersList">
                    <div style="text-align: center; padding: 40px; color: var(--gray-500);">
                        Loading reminders...
                    </div>
                </div>
            </div>
            
            <!-- Activity History -->
            <div class="cd-content-card">
                <div class="cd-card-header">
                    <h2 class="cd-card-title">Activity History</h2>
                    <p class="cd-subtitle" id="interactionLimitText"></p>
                </div>
                
                <div class="cd-activity-list" id="activityList">
                    <div style="text-align: center; padding: 40px; color: var(--gray-500);">
                        Loading activity...
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right Column -->
        <div>
            <!-- Client Information -->
            <div class="cd-content-card" style="margin-bottom: 24px;">
                <div class="cd-card-header">
                    <h2 class="cd-card-title">Client Information</h2>
                </div>
                
                <div class="cd-info-grid" id="clientInfo">
                    <div style="text-align: center; padding: 40px; color: var(--gray-500);">
                        Loading client information...
                    </div>
                </div>
                
                <!-- Address Section -->
                <div class="cd-address-card" id="addressCard">
                    <div class="cd-address-title">
                        <span>📍</span> Address
                    </div>
                    <div id="addressDisplay">
                        <div style="color: var(--gray-500); font-size: 14px;">Loading...</div>
                    </div>
                </div>
                
                <!-- Notes Section -->
                <div class="cd-notes-section" id="notesSection" style="display: none;">
                    <div class="cd-notes-title">Notes</div>
                    <div class="cd-notes-text" id="notesText"></div>
                </div>
            </div>
            
            <!-- Quick Stats -->
            <div class="cd-content-card">
                <div class="cd-card-header">
                    <h2 class="cd-card-title">Engagement Stats</h2>
                </div>
                
                <div class="cd-info-grid" id="statsGrid">
                    <div style="text-align: center; padding: 40px; color: var(--gray-500);">
                        <!--Loading stats...-->
                        Comming soon. 
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>