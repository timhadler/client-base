<script src="/js/jquery.min.js"></script>
<script src="/js/utils.js"></script>
<script type="module" src="/js/remindersScript.js"> </script>

<!-- Overlay -->
<div class="panel-overlay" id="panelOverlay"></div>

<!-- Edit reminder modal -->
<%- include('../partials/_reminderModal'); %>

<!-- Delete Modal -->
<%- include('../partials/_confirmDeleteModal'); %>

<!-- Client Detail Panel -->
<div class="client-panel" id="clientPanel">
    <div class="panel-header">
        <button class="panel-close" id="panelClose">×</button>
        <div class="panel-client-name" id="panelClientName"></div>
        <div class="panel-client-company" id="panelClientCompany"></div>
    </div>
    
    <div class="panel-body">
        <!-- Quick Actions -->
        <div class="panel-section">
            <div class="panel-section-title">Quick Actions</div>
            <div class="quick-action-btns">
                <a href="#" class="quick-action-btn primary" id="callBtn" style="display: none;">   <!-- Add feature later -->
                    <span>📞</span> Call Now
                </a>
                <a href="#" class="quick-action-btn primary" id="emailBtn" style="display: none;">  <!-- Add feature later -->
                    <span>✉️</span> Send Email
                </a>
                <a href="#" class="quick-action-btn secondary" id="viewFullBtn">
                    <span>👁️</span> Full Profile
                </a>
                <button class="quick-action-btn primary" id="markCompleteBtn">
                    <span>✓</span> Complete
                </button>
            </div>
        </div>
        
        <!-- Contact Information -->
        <div class="panel-section">
            <div class="panel-section-title">Contact Information</div>
            
            <div class="contact-item">
                <div class="contact-icon">✉️</div>
                <div class="contact-info">
                    <div class="contact-label">Email</div>
                    <div class="contact-value">
                        <a href="#" id="panelEmail"></a>
                    </div>
                </div>
                <button id="copyEmailBtn" class="copy-btn">Copy</button>
            </div>
            
            <div class="contact-item">
                <div class="contact-icon">📱</div>
                <div class="contact-info">
                    <div class="contact-label">Phone</div>
                    <div class="contact-value">
                        <a href="#" id="panelPhone"></a>
                    </div>
                </div>
                <button id="copyPhoneBtn" class="copy-btn">Copy</button>
            </div>
            
            <div class="contact-item">
                <div class="contact-icon">💼</div>
                <div class="contact-info">
                    <div class="contact-label">Position</div>
                    <div class="contact-value" id="panelPosition"></div>
                </div>
            </div>
        </div>
        
        <!-- Status & Priority -->
        <div class="panel-section">
            <div class="panel-section-title">Status & Priority</div>
            <div class="panel-badges" id="panelBadges">
                <span class="status-badge active"></span>
                <span class="priority-badge high"></span>
            </div>
        </div>
        
        <!-- Notes -->
        <div class="panel-section">
            <div class="panel-section-title">Notes</div>
            <div class="panel-notes" id="panelNotes"></div>
        </div>
        
        <!-- Interaction History section -->
        <div class="panel-section">
                <div class="panel-section-title">Interaction History</div>
                <div class="interaction-history" id="panelInteractionHistory"></div> <!-- Populated by script -->
            </div>
    </div>
</div>

<!-- Interaction modal -->
<div class="modal-overlay" id="interactionModal">
    <div class="modal-container">
        <div class="modal-header">
            <h2 class="modal-title">Record Outreach</h2>
            <button class="modal-close" id="closeInteractionModal">×</button>
        </div>
        
        <div class="modal-body">
            <form id="interactionForm">
                
                <!-- Contact Method -->
                <div class="form-group">
                    <label>How did you contact the client?</label>
                    <div class="button-group">
                        <button type="button" class="option-btn" data-method="call">
                            <span class="option-icon">📞</span>
                            <span class="option-label">Call</span>
                        </button>
                        <button type="button" class="option-btn" data-method="text">
                            <span class="option-icon">💬</span>
                            <span class="option-label">Text</span>
                        </button>
                        <button type="button" class="option-btn" data-method="email">
                            <span class="option-icon">✉️</span>
                            <span class="option-label">Email</span>
                        </button>
                        <button type="button" class="option-btn" data-method="ignored">
                            <span class="option-icon">⏭️</span>
                            <span class="option-label">Ignore</span>
                        </button>
                    </div>
                </div>
                
                <!-- Outcome (shown only for call) -->
                <div class="form-group" id="outcomeGroup" style="display: none;">
                    <label>Outcome</label>
                    <div class="button-group">
                        <button type="button" class="option-btn" data-outcome="booked">
                            <span class="option-icon">✅</span>
                            <span class="option-label">Booked</span>
                        </button>
                        <button type="button" class="option-btn" data-outcome="followup">
                            <span class="option-icon">🔄</span>
                            <span class="option-label">Follow Up</span>
                        </button>
                        <button type="button" class="option-btn" data-outcome="no_answer">
                            <span class="option-icon">📵</span>
                            <span class="option-label">No Answer</span>
                        </button>
                        <button type="button" class="option-btn" data-outcome="declined">
                            <span class="option-icon">❌</span>
                            <span class="option-label">Declined</span>
                        </button>
                    </div>
                </div>
                <!-- Reminder Options Section -->
                <div class="form-group" id="reminderOptionsGroup" style="display: none;">
                    <div class="checkbox-options-row">
                        <div class="checkbox-wrapper" id="newReminderWrapper" style="display: none;">
                            <input type="checkbox" id="createNewReminder" name="createNewReminder">
                            <label for="createNewReminder">Create a new reminder</label>
                        </div>
                        
                        <div class="checkbox-wrapper" id="nextCycleWrapper" style="display: none;">
                            <input type="checkbox" id="moveToNextCycle" name="moveToNextCycle">
                            <label for="moveToNextCycle">Move to next cycle</label>
                        </div>
                    </div>
                    <p class="labelDescriptor2" id="reminderDescription" style="display: none;"></p>
                </div>
                
                <div id="newReminderFields" style="display: none;">
                    <div class="form-group">
                        <label for="newReminderDate">Reminder Date & Time</label>
                        <input type="date" id="newReminderDate" name="newReminderDate" class="form-control">
                    </div>
                    
                    <div class="form-group">
                        <label for="newReminderNote">Reminder Note <span class="labelDescriptor"> (For your reference - adjust if needed) </span></label>
                        <input type="text" id="newReminderNote" name="newReminderNote" class="form-control" placeholder="Enter reminder details...">
                    </div>

                    <div class="checkbox-wrapper" id="importantReminderWrapper">
                        <input type="checkbox" id="reminderIsImportant" name="reminderIsImportant">
                        <label for="reminderIsImportant">Mark as important</label>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="modal-actions">
                    <button type="button" class="btn-modal btn-secondary" id="cancelInteraction">Cancel</button>
                    <button type="submit" class="btn-modal btn-primary" id="submitInteraction" disabled>Save Interaction</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Main Content -->
<main class="main-content">
    <!-- Page Header -->
    <div class="page-header">
        <div class="page-title-section">
            <h1>Reminders</h1>

            <!-- Display flash error -->
            <% if (error.length > 0) { %>
                <p class="error-message"> <%= error[0] %> </p>
            <% } else { %>
                <p class="cf-page-subtitle"> Stay on top of your client follow-ups and callbacks </p>
            <% } %>
        </div>
        <!--a href="/reminders/new" class="btn btn-primary">
            <span>📅</span> Add Reminder
        </a-->
    </div>
    
    <!-- Filter Tabs -->
    <div class="filter-tabs">
        <!-- Date Range Filter -->
        <div class="filter-dropdown-wrapper">
            <button class="tab active filter-dropdown-trigger" data-filter="dateRange" id="dateRangeTrigger">
                <span id="dateRangeLabel"> All Reminders</span>
                <span class="filter-chevron">▼</span>
            </button>
            <div class="filter-dropdown-menu" id="dateRangeMenu">
                <div class="filter-dropdown-header">Filter by Date</div>
                <button class="filter-dropdown-item selected" data-date-filter="any">
                    <span class="filter-check">✓</span> Any Date
                </button>
                <button class="filter-dropdown-item" data-date-filter="today">
                    <span class="filter-check">✓</span> Today
                    <span class="filter-count-badge" id="todayCount"></span>
                </button>
                <button class="filter-dropdown-item" data-date-filter="thisMonth">
                    <span class="filter-check">✓</span> This Month
                    <span class="filter-count-badge" id="thisMonthCount"></span>
                </button>
                <button class="filter-dropdown-item" data-date-filter="specificMonth">
                    <span class="filter-check">✓</span> Pick a Month…
                </button>
                <button class="filter-dropdown-item" data-date-filter="dateRange">
                    <span class="filter-check">✓</span> Custom Date Range…
                </button>
                <!-- Month picker -->
                <div class="date-filter-inputs" id="monthPickerInputs" style="display:none;">
                    <input type="month" id="specificMonthInput" class="form-control" style="margin: 8px 12px; width: calc(100% - 24px);">
                    <button class="date-filter-apply-btn" id="applyMonthBtn">Apply</button>
                </div>
                <!-- Date range picker -->
                <div class="date-filter-inputs" id="dateRangeInputs" style="display:none;">
                    <label class="date-filter-label">From</label>
                    <input type="date" id="dateRangeFrom" class="form-control" style="margin: 4px 12px; width: calc(100% - 24px);">
                    <label class="date-filter-label">To</label>
                    <input type="date" id="dateRangeTo" class="form-control" style="margin: 4px 12px; width: calc(100% - 24px);">
                    <button class="date-filter-apply-btn" id="applyDateRangeBtn">Apply</button>
                </div>
            </div>
        </div>
        <button class="tab important-toggle-tab" id="importantToggle" title="Show important reminders only"> Important </button>
        <button class="tab" data-filter="overdue">Overdue <span id="overdueCount"></span></button>
        <button class="tab" data-filter="followUp">Follow-ups <span id="followUpCount"></span></button>
        <button class="tab" data-filter="completed">Completed</button>
        
        <!-- Reminder Count Filter Dropdown -->
        <div class="filter-dropdown-wrapper">
            <button class="tab filter-dropdown-trigger" id="countFilterTrigger">
                <span id="countFilterLabel">Attempt #</span>
                <span class="filter-chevron">▼</span>
            </button>
            <div class="filter-dropdown-menu" id="countFilterMenu">
                <div class="filter-dropdown-header">Filter by Attempt Number</div>
                <button class="filter-dropdown-item selected" data-count="all">
                    <span class="filter-check">✓</span>
                    All Attempts
                </button>
                <div id="countOptionsContainer"></div>
            </div>
        </div>
    </div>

    <!-- Dropdown Overlay -->
    <div class="filter-dropdown-overlay" id="dropdownOverlay"></div>
    
    <!-- Table Card -->
    <div class="table-card">
        <div class="table-container">
            <table id="remindersTable">
                <thead>
                    <tr>
                        <th>Due Date</th>
                        <th>Client</th>
                        <th>Reminder Note</th>
                        <th class="reminder-count-header"># Contact Attempts</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Reminder rows will be dynamically inserted here -->
                </tbody>
            </table>
        </div>
        <div class="pagination">
        <div class="pagination-info">
            <span id="showingCount">Showing 0</span> of <span id="totalCount">0</span> reminders
        </div>
        <div class="pagination-buttons">
            <button id="loadMoreBtn" class="pagination-btn" style="display: none;">
                Load More
            </button>
        </div>
    </div>
    </div>
</main>