<script src="/js/jquery.min.js"></script>
<script src="/js/utils.js"></script>
<script type="module" src="/js/remindersScript.js"> </script>

<!-- Overlay -->
<div class="panel-overlay" id="panelOverlay"></div>

<!-- Edit reminder modal -->
<%- include('../partials/_editReminderModal'); %>

<!-- Client Detail Panel -->
<div class="client-panel" id="clientPanel">
    <div class="panel-header">
        <button class="panel-close" id="panelClose">×</button>
        <div class="panel-client-name" id="panelClientName"></div>
        <div class="panel-client-company" id="panelClientCompany"></div>
    </div>
    
    <div class="panel-body">
        <!-- Quick Actions -->
        <div class="panel-section">
            <div class="panel-section-title">Quick Actions</div>
            <div class="quick-action-btns">
                <a href="#" class="quick-action-btn primary" id="callBtn" style="display: none;">   <!-- Add feature later -->
                    <span>📞</span> Call Now
                </a>
                <a href="#" class="quick-action-btn primary" id="emailBtn" style="display: none;">  <!-- Add feature later -->
                    <span>✉️</span> Send Email
                </a>
                <a href="#" class="quick-action-btn secondary" id="viewFullBtn">
                    <span>👁️</span> Full Profile
                </a>
                <button class="quick-action-btn primary" id="markCompleteBtn">
                    <span>✓</span> Complete
                </button>
            </div>
        </div>
        
        <!-- Contact Information -->
        <div class="panel-section">
            <div class="panel-section-title">Contact Information</div>
            
            <div class="contact-item">
                <div class="contact-icon">✉️</div>
                <div class="contact-info">
                    <div class="contact-label">Email</div>
                    <div class="contact-value">
                        <a href="#" id="panelEmail"></a>
                    </div>
                </div>
                <button id="copyEmailBtn" class="copy-btn">Copy</button>
            </div>
            
            <div class="contact-item">
                <div class="contact-icon">📱</div>
                <div class="contact-info">
                    <div class="contact-label">Phone</div>
                    <div class="contact-value">
                        <a href="#" id="panelPhone"></a>
                    </div>
                </div>
                <button id="copyPhoneBtn" class="copy-btn">Copy</button>
            </div>
            
            <div class="contact-item">
                <div class="contact-icon">💼</div>
                <div class="contact-info">
                    <div class="contact-label">Position</div>
                    <div class="contact-value" id="panelPosition"></div>
                </div>
            </div>
        </div>
        
        <!-- Status & Priority -->
        <div class="panel-section">
            <div class="panel-section-title">Status & Priority</div>
            <div class="panel-badges" id="panelBadges">
                <span class="status-badge active"></span>
                <span class="priority-badge high"></span>
            </div>
        </div>
        
        <!-- Notes -->
        <div class="panel-section">
            <div class="panel-section-title">Notes</div>
            <div class="panel-notes" id="panelNotes"></div>
        </div>
        
        <!-- Interaction History section -->
        <div class="panel-section">
                <div class="panel-section-title">Interaction History</div>
                <div class="interaction-history" id="panelInteractionHistory"></div> <!-- Populated by script -->
            </div>
    </div>
</div>

<!-- Interaction modal -->
<div class="modal-overlay" id="interactionModal">
    <div class="modal-container">
        <div class="modal-header">
            <h2 class="modal-title">Record Interaction</h2>
            <button class="modal-close" id="closeInteractionModal">×</button>
        </div>
        
        <div class="modal-body">
            <form id="interactionForm">
                <input type="hidden" id="interactionReminderId" name="reminderId">
                
                <!-- Contact Method -->
                <div class="form-group">
                    <label>How did you contact the client?</label>
                    <div class="button-group">
                        <button type="button" class="option-btn" data-method="call">
                            <span class="option-icon">📞</span>
                            <span class="option-label">Call</span>
                        </button>
                        <button type="button" class="option-btn" data-method="text">
                            <span class="option-icon">💬</span>
                            <span class="option-label">Text</span>
                        </button>
                        <button type="button" class="option-btn" data-method="email">
                            <span class="option-icon">✉️</span>
                            <span class="option-label">Email</span>
                        </button>
                        <button type="button" class="option-btn" data-method="ignore">
                            <span class="option-icon">⏭️</span>
                            <span class="option-label">Ignore</span>
                        </button>
                    </div>
                    <input type="hidden" id="contactMethod" name="contactMethod" required>
                </div>
                
                <!-- Outcome (shown only for call) -->
                <div class="form-group" id="outcomeGroup" style="display: none;">
                    <label>Outcome</label>
                    <div class="button-group">
                        <button type="button" class="option-btn" data-outcome="booked">
                            <span class="option-icon">✅</span>
                            <span class="option-label">Booked</span>
                        </button>
                        <button type="button" class="option-btn" data-outcome="followup">
                            <span class="option-icon">🔄</span>
                            <span class="option-label">Follow Up</span>
                        </button>
                        <button type="button" class="option-btn" data-outcome="noanswer">
                            <span class="option-icon">📵</span>
                            <span class="option-label">No Answer</span>
                        </button>
                        <button type="button" class="option-btn" data-outcome="declined">
                            <span class="option-icon">❌</span>
                            <span class="option-label">Declined</span>
                        </button>
                    </div>
                    <input type="hidden" id="outcome" name="outcome">
                </div>
                
                <!-- Interaction Summary -->
                <div class="form-group" id="summaryGroup" style="display: none;">
                    <label>Interaction Summary</label>
                    <div class="summary-display" id="interactionSummary"></div>
                </div>
                
                <!-- New Reminder Section -->
                <div class="form-group" id="newReminderGroup" style="display: none;">
                    <div class="checkbox-wrapper">
                        <input type="checkbox" id="createNewReminder" name="createNewReminder">
                        <label for="createNewReminder">Create a new reminder</label>
                    </div>
                </div>
                
                <div id="newReminderFields" style="display: none;">
                    <div class="form-group">
                        <label for="newReminderDate">Reminder Date & Time</label>
                        <input type="datetime-local" id="newReminderDate" name="newReminderDate" class="form-control">
                    </div>
                    
                    <div class="form-group">
                        <label for="newReminderNote">Reminder Note <span class="labelDescriptor"> (For your reference - adjust if needed) </span></label>
                        <input type="text" id="newReminderNote" name="newReminderNote" class="form-control" placeholder="Enter reminder details...">
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="modal-actions">
                    <button type="button" class="btn-modal btn-secondary" id="cancelInteraction">Cancel</button>
                    <button type="submit" class="btn-modal btn-primary" id="submitInteraction" disabled>Save Interaction</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Main Content -->
<main class="main-content">
    <!-- Page Header -->
    <div class="page-header">
        <div class="page-title-section">
            <h1>Reminders</h1>
            <p>Stay on top of your client follow-ups and callbacks</p>
        </div>
        <a href="/reminders/new" class="btn btn-primary">
            <span>📅</span> Add Reminder
        </a>
    </div>
    
    <!-- Filter Tabs -->
    <div class="filter-tabs">
        <button class="tab active" data-filter="all">All Reminders</button>
        <button class="tab" data-filter="overdue">Overdue <span id="overdueCount"></span></button>
        <button class="tab" data-filter="today">Today <span id="todayCount"></span></button>
        <button class="tab" data-filter="upcoming">Upcoming <span id="upcomingCount"></span></button>
        <button class="tab" data-filter="completed">Completed</button>
    </div>
    
    <!-- Table Card -->
    <div class="table-card">
        <div class="table-container">
            <table id="remindersTable">
                <thead>
                    <tr>
                        <th>Due Date</th>
                        <th>Client</th>
                        <th>Reminder Note</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Reminder rows will be dynamically inserted here -->
                </tbody>
            </table>
        </div>
    </div>
</main>