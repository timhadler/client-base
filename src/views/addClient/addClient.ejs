<!-- Left pane (call list) -->
<%//- include("../partials/call-list.ejs", {calls:callList}) %>


<!-- Client details pane -->
<div class="grid_col_1">
    <div class="margin_t_l margin_l_l">
        <!-- Details header -->
        <h2 class="size_small bold"> Add Customer </h2>

        <!-- Error message -->
        <% if (locals.error) { %>
            <p style="color:red"> <%= locals.error %> </p>
        <% } %>

        <form action= "/clients/add-client" method="POST" class="details_grid pad-t-med pad-l-med">
            <div class="grid_a_1">
                <%- include("../partials/inputForms/client") %>
            </div>

            <div class="grid_a_2">
                <%- include("../partials/inputForms/contact") %>
            </div>

            <div class="grid_a_3_4">
                <div class="add_button flex flex-jc-r flex-ai-b">
                    <button type="submit" class="button_primary"> Submit </button>
                    <a href="/" class="button button_secondary button_cancel"> Cancel </a>
                </div>
            </div>
        </form>
    </div>
</div>