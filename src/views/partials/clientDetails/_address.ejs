<!-- Add popup -->
<div>
    <form id="addAddressPopup" class="popup" action="/clients/add-address-<%=client_id%>" method="POST">
        <%- include("../inputForms/address") %>
        <div class="flex flex-ai-c flex-jc-r">
            <button type="submit" class="button_primary margin_r_sm"> Submit </button>
            <button id="addressCloseAddFormButton" type="button" class="button_secondary button_cancel"> Cancel </button>
        </div>
    </form>
</div>

<% for (let i=0; i < data.length; i++) { %>
    <li>
        <!-- Edit popup -->
        <div id="<%= "addressEditPopup-" + data[i].id %>" class="popup">
            <form action="/clients/edit-address/<%= data[i].id %>-<%= data[i].client_id %>" method="POST">
                <%- include("../inputForms/address", { street:data[i].street, suburb:data[i].suburb, city:data[i].city, pc:data[i].pc, area:data[i].area, fa:data[i].fa }) %>
                <div>
                    <button type="submit" class="button_secondary"> Submit </button>
                    <button id="<%= data[i].id %>" name="addressCancelPopupButton" type="button" class="button_secondary button_cancel"> Cancel </button>
                </div>
            </form>
        </div>

        <div class="flex flex-ai-c flex-jc-sb">
            <p> <%=data[i].street%> </p>
            <div id="test" class="flex flex-ai-c">
                <button id="<%= data[i].id %>" name="addressEditButton" type="button" class="button button_secondary"> Edit </button>
                <form action="/clients/delete-address/<%= data[i].client_id %>-<%= data[i].id %>?_method=DELETE" method="POST">
                    <button type="submit"><span class="close_form"></span></button>
                </form>
            </div>
        </div> 
    </li>
<% } %> 