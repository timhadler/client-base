<script type="module" src="/js/clientListScript.js"> </script>

<!-- Add client popup -->
<div id="addClientPopup" class="hidden popup" style="margin-left: 50%;">
    <div class="flex flex-ai-c flex-jc-sb">
        <h3 class="italic"> Add Customer </h3> <br />
        <span id="addClientCloseButton" class="close_form"></span>
    </div>
    <br />
    <form action= "/clients/add-client" method="POST">
        <%- include("../inputForms/client") %>
        <label> Comments: </label> <br />
        <textarea name="comments" class="height-100 width-100" cols="21" rows="6"><%= locals.comments %></textarea> <br /> <br />

        <div class="center-x">
            <label> Call back on: </label> <br />
            <%- include("../inputForms/call") %>
            <br /> <br />
            <button type="submit" class="button_primary"> Submit </button>
        </div>
    </form>
</div>

<!-- Left Pane -->
<div id="leftPane" name="test" class="grid_col_1 section_divider_clientList">
    <div class="pad-t-med pad-r-sm">
        <!-- Error message for duplicate client entry -->
        <p class="error_message size_small"> <%= locals.error %> </p>

        <!-- list header -->
        <p class="size_small margin_t_sm"> 
            <% if(typeof locals.search != 'undefined' && locals.search.length > 0) { %> 
                <div class="flex flex-ai-c flex-jc-sb">
                    Search: <%= locals.search %> 
                    <a href="/clients/"><span class="close_form"></span></a>
                </div>
            <% } else { %>
                Client List
            <% } %>
        </p>
        <hr class="line_header">

        <!-- list -->
        <div class="margin_t_sm">
            <ul id="cList">
                <% 
                let reUrl = "/clients/?";
                if (typeof locals.search != 'undefined' && locals.search.length > 0) {
                    reUrl = reUrl + "search=" + locals.search.replace(/ /g, "+") + "&";
                }
                    //let str = "/clients/?search=" + locals.search + "?clientID=" + clients[i].id 
                %>
                <% for (let i = 0; i < locals.clients.length; i++) { %>
                    <li class="list_item_divider"><a href=<%=reUrl + "clientID=" + clients[i].id  %> class="nameButton"> <%= clients[i].name %> </a></li>
                <% } %>
            </ul>
        </div>
    </div>
</div>