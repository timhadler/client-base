<!-- Reminder Edit Modal -->
<div class="cd-modal-overlay" id="reminderModal">
    <div class="cd-modal-container">
        <div class="cd-modal-header">
            <h2 class="cd-modal-title" id="reminderModalTitle">Edit Reminder</h2>
            <button class="cd-modal-close" id="closeReminderModal">×</button>
        </div>
        <div class="cd-modal-body">
            <form id="reminderForm">
                <input type="hidden" id="editReminderId">
                <input type="hidden" id="rModalClientId">
                
                <div class="cd-form-group">
                    <label>Date & Time</label>
                    <input type="date" class="cd-form-control" id="editReminderDate" required>
                </div>
                
                <div class="cd-form-group">
                    <label>Reminder Note</label>
                    <textarea class="cd-form-control" id="editReminderNote" rows="3" required></textarea>
                </div>
                
                <div class="checkbox-wrapper" id="editImportantReminderWrapper">
                    <input type="checkbox" id="editReminderImportant" name="editReminderImportant">
                    <label for="editReminderImportant">Mark as important</label>
                </div>
                
                <div class="cd-modal-actions">
                    <button type="button" class="cd-btn-modal cd-btn-secondary" id="cancelReminder">Cancel</button>
                    <button type="submit" class="cd-btn-modal cd-btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>