<div style="width: 98%;" class="flex flex-ai-c flex-jc-sb list_item_divider">
    <div class="flex flex-ai-c">
        <% if (locals.client.status != "confirmed") { %>
            <input type="checkbox" form="checkBoxForm" name="selectedClients" value="<%= locals.client.rId %>">
        <% } %>
        <button id="<%= locals.client.rId %>" name="clientCallButton" type="button" class="nameButton"> <%= locals.client.name %> </button>
    </div>
    <% if (locals.client.flag && locals.client.status != "confirmed") { %> 
        <p class="flagCheckBox">  </p> 
    <% } %>
</div>