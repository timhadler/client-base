<script type="module" src="/js/callListScript.js"> </script>

<form class="grid_col_1 margin_t_med margin_b_med" id="datesForm" action="/setDates" method="GET">
    <div class="flex flex-ai-c">
        <input class="margin_r_sm" id="date1_input" type="date" name="date1" value="<%= D1 %>">
        to
        <input class="margin_l_sm" id="date2_input" type="date" name="date2" value="<%= D2 %>">
        <button class="button_secondary margin_l_sm" type="submit"> Set </button>
    </div>
</form>

<div class="grid_col_1">
    <p class="flex flex-jc-c"> Call List </p>
    <hr />
    <div class="inner_section">
        <ul id="cList" class="section_divider">
            <% for (let i = 0; i < CLIENT_LIST.length; i++) { %>
                <% if (CLIENT_LIST[i].status == "call") { %>
                    <li class="positionRelative"> 
                        <button id="<%= CLIENT_LIST[i].id %>" name="clientCallButton" type="button" class="color_secondary"> <%= CLIENT_LIST[i].name %> </button>
                        <!--<li><a href=<%="/clients/" + CLIENT_LIST[i].id%> class="color_secondary"> <%= CLIENT_LIST[i].name %> </a></li>-->   
                        
                        <!-- Client Popup -->
                        <form id=<%= "clientPopup-" + CLIENT_LIST[i].id %> class="clientPopup" action="/clients/set-client-status-<%= CLIENT_LIST[i].id %>" method="POST">
                            <input type="radio" name="clientStatus" value="tbc">
                            <label> To be Confirmed </label> <br />
                            <input type="radio" name="clientStatus" value="confirmed">
                            <label> Confirmed </label>
                            <br /><br />
                            <a href=<%="/clients/" + CLIENT_LIST[i].id%> class="color_secondary"> Client Details </a>
                            <br />
                            <button type="submit" class="button_primary"> Submit </button>
                        </form>
                    </li>
                <% } %>
            <% } %>
        </ul>
    </div>

</div>

<div class="grid_col_2">
    <p class="flex flex-jc-c"> To be confirmed </p>
    <hr />
    <div class="inner_section section_divider">
        <ul id="tbcList">
            <% for (let i = 0; i < CLIENT_LIST.length; i++) { %>
                <% if (CLIENT_LIST[i].status == "tbc") { %>
                   <li> <%= CLIENT_LIST[i].name %> </li> 
                <% } %>
            <% } %>
        </ul>
    </div>
</div>

<div class="grid_col_3">
    <p class="flex flex-jc-c"> Confirmed </p>
    <hr />
    <div>
        <ul id="callList"> </ul>
    </div>
</div>